# lang_IPEA_editorial - Configuração do provedor LLM
# Crie um arquivo .env na raiz do projeto com apenas o bloco do seu provedor.
# Os valores padrão estão em src/editorial_docx/config.py.

# === Provedor (obrigatório) ===
# LLM_PRIMARY_PROVIDER=openai | openai_compatible | ollama
# LLM_PROVIDER=openai | ollama | openai_compatible
# LLM_MODEL=gpt-5.2 | llama3.1:8b | nome-do-modelo
# LLM_BASE_URL= (obrigatório para ollama e openai_compatible)
# LLM_API_KEY= (obrigatório para openai; opcional para os demais)

# === OpenAI ===
# LLM_PRIMARY_PROVIDER=openai
OPENAI_MODEL=gpt-5.2
OPENAI_API_KEY=sk-sua-chave-aqui

# === Ollama (local) ===
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1:8b
# LLM_API_KEY=ollama

# === OpenAI-compatible (servidor interno) ===
# LLM_PRIMARY_PROVIDER=openai_compatible
# LLM_BASE_URL=http://servidor-interno/v1
# LLM_MODEL=nome-do-modelo
# LLM_API_KEY=SEU_TOKEN

# === IpeaGPT / IpeaIA ===
# LLM_PRIMARY_PROVIDER=openai_compatible
# LLM_BASE_URL=https://ipeagpt.ipea.gov.br/api/v1
# LLM_MODEL=glm-5.2
# LLM_API_KEY=SEU_TOKEN
# Endpoints usados internamente:
# GET https://ipeagpt.ipea.gov.br/api/v1/models
# POST https://ipeagpt.ipea.gov.br/api/v1/chat/completions

# === Aliases legados (fallback se LLM_* não existir) ===
# OPENAI_API_KEY, OPENAI_MODEL, OPENAI_BASE_URL
# OLLAMA_API_KEY, OLLAMA_MODEL, OLLAMA_BASE_URL

# === Configurações opcionais (valores padrão em config.py) ===
# LLM_SEED=7
# LLM_MAX_RETRIES=3
# LLM_RETRY_BACKOFF_SECONDS=1.0
# LLM_TIMEOUT_SECONDS=120

# === Grounding externo opcional ===
# OPENALEX_API_KEY=chave-gratuita-do-openalex
# OPENALEX_EMAIL=seu-email@dominio.gov.br
